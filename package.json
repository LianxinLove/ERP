{
  "name": "erp-system",
  "version": "1.0.0",
  "private": true,
  "description": "ERP系统",
  "scripts": {
    "dev": "concurrently \"pnpm --filter frontend dev\" \"pnpm --filter backend dev\"",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build": "pnpm --filter frontend build && pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "lint": "pnpm --filter frontend lint && pnpm --filter backend lint",
    "lint:frontend": "pnpm --filter frontend lint",
    "lint:backend": "pnpm --filter backend lint",
    "format": "pnpm --filter frontend format && pnpm --filter backend format",
    "format:frontend": "pnpm --filter frontend format",
    "format:backend": "pnpm --filter backend format",
    "test": "pnpm --filter frontend test && pnpm --filter backend test",
    "test:frontend": "pnpm --filter frontend test",
    "test:backend": "pnpm --filter backend test",
    "clean": "pnpm --filter frontend clean && pnpm --filter backend clean && rm -rf node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@tanstack/react-query-devtools": "^5.101.0",
    "next-themes": "^0.4.6",
    "sonner": "^2.0.7"
  }
}
