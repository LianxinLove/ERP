# ERP系统后端 - 环境变量配置示例

# ============ API配置 ============
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# ============ 数据库配置 (SQLite) ============
# SQLite 数据库文件路径（相对于运行目录）
DB_PATH=./erp_system.db

# ============ JWT配置 ============
# 重要: 生产环境必须使用强随机密钥！
# 生成方法: openssl rand -hex 32 (64字符十六进制) 或 python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
# 示例 (仅用于开发环境): 3f45c0c02210e83369cc4ebe742c475da5ae2099e6f6c5a2c3a63c31f6615575
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============ CORS配置 ============
# 多个域名用逗号分隔（不含空格）
# 开发环境示例: CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 生产环境示例: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============ 文件存储配置 ============
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# ============ 分页配置 ============
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
